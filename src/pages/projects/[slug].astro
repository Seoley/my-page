---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`${project.data.title} | 이설의`} description={project.data.description}>
  <div class="w-full lg:flex-1 lg:max-w-[calc(100%-340px)] p-6 lg:p-8">
    <!-- Back Button -->
    <a href={`${base}/projects`} class="inline-flex items-center gap-2 text-muted hover:text-[var(--accent)] mb-8 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m12 19-7-7 7-7"></path>
        <path d="M19 12H5"></path>
      </svg>
      프로젝트 목록
    </a>

    <!-- Project Header -->
    <section class="mb-8">
      <h1 class="text-2xl lg:text-3xl font-bold mb-4">{project.data.title}</h1>
      <p class="text-lg text-muted mb-6">{project.data.description}</p>

      <!-- Project Info -->
      {(project.data.period || project.data.role || project.data.team || project.data.result) && (
        <table class="info-table mb-6">
          {project.data.period && (
            <tr>
              <th>기간</th>
              <td>{project.data.period}</td>
            </tr>
          )}
          {project.data.role && (
            <tr>
              <th>역할</th>
              <td>{project.data.role}</td>
            </tr>
          )}
          {project.data.team && (
            <tr>
              <th>팀 구성</th>
              <td>{project.data.team}</td>
            </tr>
          )}
          {project.data.result && (
            <tr>
              <th>성과</th>
              <td>{project.data.result}</td>
            </tr>
          )}
        </table>
      )}

      <!-- Tags -->
      <div class="flex flex-wrap gap-2">
        {project.data.tags.map((tag: string) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    </section>

    <!-- Project Content -->
    <article class="prose prose-lg max-w-none">
      <Content />
    </article>
  </div>

  <Sidebar />

  <!-- Image Lightbox Modal -->
  <div id="lightbox" class="lightbox">
    <div class="lightbox-overlay"></div>
    <div class="lightbox-content">
      <img id="lightbox-img" src="" alt="" />
    </div>
  </div>
</BaseLayout>

<style is:global>
  .prose h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: var(--text);
  }
  .prose h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: var(--text);
  }
  .prose p {
    margin-bottom: 1rem;
    color: var(--muted);
  }
  .prose ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .prose li {
    color: var(--muted);
    margin-bottom: 0.5rem;
  }
  .prose strong {
    color: var(--text);
  }
  .prose code {
    background-color: var(--border);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
  }

  /* Table Styles */
  .prose table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin: 1.5rem 0;
    font-size: 0.875rem;
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid var(--border);
    background-color: var(--card-bg);
  }
  .prose thead {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(59, 130, 246, 0.05));
  }
  .prose th {
    padding: 1rem 1.25rem;
    text-align: left;
    font-weight: 600;
    color: var(--text);
    border-bottom: 2px solid var(--border);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .prose td {
    padding: 0.875rem 1.25rem;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }
  .prose tbody tr:last-child td {
    border-bottom: none;
  }
  .prose tbody tr {
    transition: background-color 0.15s ease;
  }
  .prose tbody tr:hover {
    background-color: rgba(59, 130, 246, 0.08);
  }
  /* Highlight best result */
  .prose td strong {
    color: var(--accent);
    font-weight: 600;
  }

  /* Blockquote Styles */
  .prose blockquote {
    border-left: 4px solid var(--accent);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    background: linear-gradient(90deg, rgba(59, 130, 246, 0.08), transparent);
    border-radius: 0 0.75rem 0.75rem 0;
  }
  .prose blockquote p {
    margin: 0;
    color: var(--text);
    font-weight: 500;
  }
  .prose blockquote strong {
    color: var(--accent);
  }

  /* Image styles - clickable */
  .prose img {
    cursor: zoom-in;
    border-radius: 0.75rem;
    border: 1px solid var(--border);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .prose img:hover {
    transform: scale(1.01);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  }

  /* Centered small image */
  .prose .img-center {
    display: flex;
    justify-content: center;
    margin: 1.5rem 0;
  }
  .prose .img-center img {
    max-width: 50%;
    height: auto;
  }

  /* Lightbox Styles */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s, visibility 0.3s;
  }
  .lightbox.active {
    opacity: 1;
    visibility: visible;
  }
  .lightbox-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(4px);
  }
  .lightbox-content {
    position: relative;
    max-width: 90vw;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .lightbox-content img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 0.5rem;
    cursor: pointer;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const overlay = document.querySelector('.lightbox-overlay');

    // Open lightbox on image click
    document.querySelectorAll('.prose img').forEach(img => {
      img.addEventListener('click', (e) => {
        const target = e.target as HTMLImageElement;
        lightboxImg.src = target.src;
        lightboxImg.alt = target.alt;
        lightbox?.classList.add('active');
        document.body.style.overflow = 'hidden';
      });
    });

    // Close lightbox
    function closeLightbox() {
      lightbox?.classList.remove('active');
      document.body.style.overflow = '';
    }

    // Close on overlay or image click
    overlay?.addEventListener('click', closeLightbox);
    lightboxImg?.addEventListener('click', closeLightbox);

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && lightbox?.classList.contains('active')) {
        closeLightbox();
      }
    });
  });
</script>

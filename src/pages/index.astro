---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
---

<BaseLayout title="이설의 | AI Engineer">
  <!-- Main Content -->
  <div class="w-full lg:w-[calc(100%-340px)] p-6 lg:p-8">
    <!-- Hero Section -->
    <section class="lg:min-h-[50vh] flex flex-col justify-end mb-12">
      <h1 class="text-3xl lg:text-4xl font-bold mb-6 leading-tight">
        AI 엔지니어, <span class="text-[var(--accent)]">이설의</span>입니다
      </h1>
      <p class="text-lg text-muted leading-relaxed mb-8">
        RAG 아키텍처 설계부터 LLM 벤치마크까지, AI 서비스 개발 전반을 다루는 개발자입니다.<br class="hidden lg:block">
        Claude Code와 함께하는 바이브코딩으로 개발 생산성을 극대화합니다.<br class="hidden lg:block">
        AI를 도구가 아닌 협업자로 활용하여, 복잡한 도메인도 빠르게 학습하고 구현합니다.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/projects" class="btn px-5 py-2.5 rounded-lg text-sm font-medium">
          프로젝트 보기
        </a>
        <a href="/contact" class="px-5 py-2.5 rounded-lg text-sm font-medium border border-[var(--border)] hover:border-[var(--accent)] transition-colors">
          연락하기
        </a>
      </div>
    </section>

    <!-- Recent Projects -->
    <section>
      <h2 class="text-xl font-bold mb-6">최근 프로젝트</h2>

      <div class="space-y-4">
        <a href="/projects" class="card p-5 block hover:border-[var(--accent)] transition-colors group">
          <h3 class="font-semibold mb-2 group-hover:text-[var(--accent)] transition-colors">RAG 기반 챗봇 솔루션</h3>
          <p class="text-sm text-muted mb-3">기업 맞춤형 RAG 기반 챗봇 솔루션. 관공서 폐쇄망 실서비스 운영 중.</p>
          <div class="flex flex-wrap gap-2">
            <span class="tag">FastAPI</span>
            <span class="tag">LangChain</span>
            <span class="tag">FAISS</span>
            <span class="tag">Docker</span>
          </div>
        </a>

        <a href="/projects" class="card p-5 block hover:border-[var(--accent)] transition-colors group">
          <h3 class="font-semibold mb-2 group-hover:text-[var(--accent)] transition-colors">하수처리 공정 지능화 시스템</h3>
          <p class="text-sm text-muted mb-3">A2O 하수처리 공정 AI 예측 및 제어인자 최적화 시스템. 27개 API 엔드포인트.</p>
          <div class="flex flex-wrap gap-2">
            <span class="tag">FastAPI</span>
            <span class="tag">PyTorch</span>
            <span class="tag">Scikit-learn</span>
          </div>
        </a>

        <a href="/projects" class="card p-5 block hover:border-[var(--accent)] transition-colors group">
          <h3 class="font-semibold mb-2 group-hover:text-[var(--accent)] transition-colors">육아상담 AI 챗봇 서비스</h3>
          <p class="text-sm text-muted mb-3">0~36개월 영유아 부모 대상 RAG 기반 육아상담 챗봇. AI 시험인증 정확도 90.9% 달성.</p>
          <div class="flex flex-wrap gap-2">
            <span class="tag">RAG</span>
            <span class="tag">BERT</span>
            <span class="tag">NHN Cloud</span>
          </div>
        </a>
      </div>

      <p class="text-center mt-8">
        <a href="/projects" class="text-[var(--accent)] hover:underline">
          모든 프로젝트 보기 &rarr;
        </a>
      </p>
    </section>
  </div>

  <!-- Sidebar -->
  <Sidebar />
</BaseLayout>

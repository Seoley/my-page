---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';

const base = import.meta.env.BASE_URL;
const allProjects = await getCollection('projects');
const recentProjects = allProjects.sort((a, b) => a.data.order - b.data.order).slice(0, 3);
---

<BaseLayout title="이설의 | AI Engineer">
  <div class="w-full lg:flex-1 lg:max-w-[calc(100%-340px)] p-6 lg:p-8">
    <!-- Hero Section -->
    <section class="pt-8 lg:pt-16 mb-12">
      <h1 class="text-3xl lg:text-4xl font-bold mb-6 leading-tight">
        AI 엔지니어, <span class="text-[var(--accent)]">이설의</span>입니다
      </h1>
      <p class="text-lg text-muted leading-relaxed mb-8">
        RAG 아키텍처 설계부터 LLM 벤치마크까지, AI 서비스 개발 전반을 다루는 개발자입니다.<br class="hidden lg:block">
        Claude Code와 함께하는 바이브코딩으로 개발 생산성을 극대화합니다.<br class="hidden lg:block">
        AI를 도구가 아닌 협업자로 활용하여, 복잡한 도메인도 빠르게 학습하고 구현합니다.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href={`${base}/projects`} class="btn px-5 py-2.5 rounded-lg text-sm font-medium">
          프로젝트 보기
        </a>
        <a href={`${base}/contact`} class="px-5 py-2.5 rounded-lg text-sm font-medium border border-[var(--border)] hover:border-[var(--accent)] transition-colors">
          연락하기
        </a>
        <a href={`${base}/resume/resume.pdf`} target="_blank" class="px-5 py-2.5 rounded-lg text-sm font-medium border border-[var(--border)] hover:border-[var(--accent)] transition-colors">
          이력서
        </a>
      </div>
    </section>

    <!-- Recent Projects -->
    <section>
      <h2 class="text-xl font-bold mb-6">최근 프로젝트</h2>

      <div class="space-y-4">
        {recentProjects.map((project) => (
          <a href={`${base}/projects/${project.slug}`} class="card p-5 block hover:border-[var(--accent)] transition-colors group">
            <h3 class="font-semibold mb-2 group-hover:text-[var(--accent)] transition-colors">
              {project.data.title}
            </h3>
            <p class="text-sm text-muted mb-3">{project.data.description}</p>
            {project.data.period && (
              <p class="text-xs text-muted mb-2">{project.data.period}</p>
            )}
            <div class="flex flex-wrap gap-2">
              {project.data.tags.slice(0, 4).map((tag: string) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>

      <p class="text-center mt-8">
        <a href={`${base}/projects`} class="text-[var(--accent)] hover:underline">
          모든 프로젝트 보기 &rarr;
        </a>
      </p>
    </section>
  </div>

  <Sidebar />
</BaseLayout>

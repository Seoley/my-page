---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
---

<BaseLayout title="Contact | 이설의" description="AI 엔지니어 이설의 연락처">
  <!-- Main Content -->
  <div class="w-full lg:w-[calc(100%-340px)] p-6 lg:p-8">
    <!-- Hero Section -->
    <section class="lg:min-h-[40vh] flex flex-col justify-end mb-12">
      <h1 class="text-3xl lg:text-4xl font-bold mb-4">Contact</h1>
      <p class="text-lg text-muted">
        Feel free to reach out to me for anything.<br>
        Email me for serious work inquiries.
      </p>
    </section>

    <!-- Contact Links -->
    <section class="mb-12">
      <div class="space-y-4">
        <a
          href="mailto:dltjfdml@gmail.com"
          class="card p-5 flex items-center gap-4 hover:border-[var(--accent)] transition-colors group"
        >
          <div class="w-12 h-12 rounded-full bg-[var(--accent)]/10 flex items-center justify-center text-[var(--accent)]">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
          </div>
          <div>
            <p class="font-semibold group-hover:text-[var(--accent)] transition-colors">Email</p>
            <p class="text-sm text-muted">dltjfdml@gmail.com</p>
          </div>
        </a>

        <a
          href="https://github.com/Seoley"
          target="_blank"
          rel="noopener noreferrer"
          class="card p-5 flex items-center gap-4 hover:border-[var(--accent)] transition-colors group"
        >
          <div class="w-12 h-12 rounded-full bg-[var(--accent)]/10 flex items-center justify-center text-[var(--accent)]">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
              <path d="M9 18c-4.51 2-5-2-7-2"></path>
            </svg>
          </div>
          <div>
            <p class="font-semibold group-hover:text-[var(--accent)] transition-colors">GitHub</p>
            <p class="text-sm text-muted">@Seoley</p>
          </div>
        </a>
      </div>
    </section>
  </div>

  <!-- Sidebar -->
  <Sidebar />
</BaseLayout>

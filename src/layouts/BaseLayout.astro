---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "AI 엔지니어 이설의 포트폴리오" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title}</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css">
</head>
<body class="min-h-screen">
  <div class="relative min-h-screen max-w-8xl mx-auto">
    <main class="relative z-10 min-h-screen flex flex-col lg:flex-row">

      <!-- Desktop Navigation (Left Sidebar) -->
      <div class="hidden lg:block lg:w-20 border-r border-[var(--border)] fixed h-screen">
        <nav class="w-full h-full flex flex-col gap-6 items-center justify-center">
          <a
            href="/"
            class:list={["p-3 rounded-lg transition-colors", currentPath === "/" ? "text-[var(--accent)] bg-[var(--accent)]/10" : "text-[var(--muted)] hover:text-[var(--accent)]"]}
            title="Home"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"></path>
              <path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            </svg>
          </a>
          <a
            href="/about"
            class:list={["p-3 rounded-lg transition-colors", currentPath === "/about/" || currentPath === "/about" ? "text-[var(--accent)] bg-[var(--accent)]/10" : "text-[var(--muted)] hover:text-[var(--accent)]"]}
            title="About"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          </a>
          <a
            href="/projects"
            class:list={["p-3 rounded-lg transition-colors", currentPath.startsWith("/projects") ? "text-[var(--accent)] bg-[var(--accent)]/10" : "text-[var(--muted)] hover:text-[var(--accent)]"]}
            title="Projects"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"></path>
            </svg>
          </a>
          <a
            href="/contact"
            class:list={["p-3 rounded-lg transition-colors", currentPath === "/contact/" || currentPath === "/contact" ? "text-[var(--accent)] bg-[var(--accent)]/10" : "text-[var(--muted)] hover:text-[var(--accent)]"]}
            title="Contact"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"></path>
              <path d="m21.854 2.147-10.94 10.939"></path>
            </svg>
          </a>
        </nav>
      </div>

      <!-- Main Content Area -->
      <div class="flex flex-1 lg:ml-20 overflow-y-auto hide-scrollbar flex-col lg:flex-row pb-20 lg:pb-0">
        <slot />
      </div>

      <!-- Mobile Navigation (Bottom) -->
      <nav class="fixed bottom-0 left-0 right-0 z-50 bg-[var(--surface)]/80 backdrop-blur-sm border-t border-[var(--border)] lg:hidden">
        <div class="flex justify-around items-center h-16 px-4">
          <a
            href="/"
            class:list={["p-3 rounded-lg transition-colors", currentPath === "/" ? "text-[var(--accent)]" : "text-[var(--muted)]"]}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"></path>
              <path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            </svg>
          </a>
          <a
            href="/about"
            class:list={["p-3 rounded-lg transition-colors", currentPath === "/about/" || currentPath === "/about" ? "text-[var(--accent)]" : "text-[var(--muted)]"]}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          </a>
          <a
            href="/projects"
            class:list={["p-3 rounded-lg transition-colors", currentPath.startsWith("/projects") ? "text-[var(--accent)]" : "text-[var(--muted)]"]}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"></path>
            </svg>
          </a>
          <a
            href="/contact"
            class:list={["p-3 rounded-lg transition-colors", currentPath === "/contact/" || currentPath === "/contact" ? "text-[var(--accent)]" : "text-[var(--muted)]"]}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"></path>
              <path d="m21.854 2.147-10.94 10.939"></path>
            </svg>
          </a>
        </div>
      </nav>

    </main>
  </div>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
